@page
@using PersonalBudget.Localization
@using Microsoft.Extensions.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model PersonalBudget.Pages.Categories.EditModalModel
@inject IStringLocalizer<PersonalBudgetResource> L

<abp-dynamic-form abp-model="Category" asp-page="/Categories/EditModal">
    <abp-modal>
        <abp-modal-header title="@L["EditCategory"].Value"></abp-modal-header>
        <abp-modal-body>
            <abp-form-content />
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Save | AbpModalButtons.Cancel)"></abp-modal-footer>
    </abp-modal>
</abp-dynamic-form>
