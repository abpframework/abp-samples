@page
@using BookReviewTracker4.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<BookReviewTracker4Resource> L

@section content_toolbar {
    <h4><i class="fa fa-chart-line me-2"></i>@L["Dashboard"]</h4>
}

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white shadow-sm">
            <div class="card-body d-flex align-items-center">
                <i class="fa fa-user-pen fa-2x me-3"></i>
                <div>
                    <h6 class="card-title mb-0">@L["TotalAuthors"]</h6>
                    <h2 class="mb-0" id="totalAuthors">-</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white shadow-sm">
            <div class="card-body d-flex align-items-center">
                <i class="fa fa-book fa-2x me-3"></i>
                <div>
                    <h6 class="card-title mb-0">@L["TotalBooks"]</h6>
                    <h2 class="mb-0" id="totalBooks">-</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-white shadow-sm">
            <div class="card-body d-flex align-items-center">
                <i class="fa fa-star fa-2x me-3"></i>
                <div>
                    <h6 class="card-title mb-0">@L["TotalReviews"]</h6>
                    <h2 class="mb-0" id="totalReviews">-</h2>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Top Rated Books -->
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fa fa-trophy text-warning me-2"></i>@L["TopRatedBooks"]</h5>
                <a href="/Books" class="btn btn-sm btn-outline-primary">@L["ViewAll"]</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@L["Title"]</th>
                            <th>@L["AuthorName"]</th>
                            <th>@L["AverageRating"]</th>
                            <th>@L["ReviewCount"]</th>
                        </tr>
                    </thead>
                    <tbody id="topBooksBody">
                        <tr><td colspan="4" class="text-center text-muted py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Latest Reviews -->
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fa fa-clock text-info me-2"></i>@L["LatestReviews"]</h5>
                <a href="/Reviews" class="btn btn-sm btn-outline-primary">@L["ViewAll"]</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@L["BookTitle"]</th>
                            <th>@L["Rating"]</th>
                            <th>@L["Comment"]</th>
                            <th>@L["ReviewDate"]</th>
                        </tr>
                    </thead>
                    <tbody id="latestReviewsBody">
                        <tr><td colspan="4" class="text-center text-muted py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Pages/Dashboard/Index.js"></script>
}
