@code
{
    private List<CategoryLookupDto> _categoryLookup = new();

    public Recipes()
    {
        CreatePolicyName = RecipeOrganizerPermissions.Recipes.Create;
        UpdatePolicyName = RecipeOrganizerPermissions.Recipes.Edit;
        DeletePolicyName = RecipeOrganizerPermissions.Recipes.Delete;

        LocalizationResource = typeof(RecipeOrganizerResource);
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var result = await AppService.GetCategoryLookupAsync();
        _categoryLookup = result.Items.ToList();
    }

    protected override string GetDeleteConfirmationMessage(RecipeDto entity)
    {
        return string.Format(L["RecipeDeletionConfirmationMessage"], entity.Title);
    }

    public override async Task OpenEditModalAsync(RecipeDto entity)
    {
        await base.OpenEditModalAsync(entity);
        // Populate ingredients from the read DTO since the mapper ignores them
        EditingEntity.Ingredients = entity.Ingredients
            .Select(i => new CreateUpdateIngredientDto
            {
                Name = i.Name,
                Quantity = i.Quantity,
                Unit = i.Unit
            })
            .ToList();
    }

    private void AddIngredient(CreateUpdateRecipeDto recipe)
    {
        recipe.Ingredients.Add(new CreateUpdateIngredientDto());
    }

    private void RemoveIngredient(CreateUpdateRecipeDto recipe, CreateUpdateIngredientDto ingredient)
    {
        recipe.Ingredients.Remove(ingredient);
    }
}
