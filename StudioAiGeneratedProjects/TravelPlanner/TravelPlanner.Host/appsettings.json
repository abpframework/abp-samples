{
  "App": {
    "SelfUrl": "https://localhost:44312",
    "CorsOrigins": "https://*.TravelPlanner.com,http://localhost:44312",
    "RedirectAllowedUrls": "http://localhost:44312"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Data Source=../TravelPlanner.db;"
  },
  "AuthServer": {
    "Authority": "https://localhost:44312",
    "SwaggerClientId": "TravelPlanner_Swagger",
    "CertificatePassPhrase": "4a53ea02-df1e-4928-a10c-f3d1d36780b8"
  },
  "Settings": {
    "Abp.Identity.Password.RequireNonAlphanumeric": "false",
    "Abp.Identity.Password.RequireLowercase": "false",
    "Abp.Identity.Password.RequireUppercase": "false",
    "Abp.Identity.Password.RequireDigit": "false"
  },
  "OpenTripMap": {
    "ApiKey": "YOUR_API_KEY_HERE",
    "BaseUrl": "https://api.opentripmap.com/0.1/en/"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "I7BFzKKYoeQ4oeZX"
  },
  "OpenIddict": {
    "Applications": {
      "TravelPlanner_Blazor": {
        "ClientId": "TravelPlanner_Blazor",
        "RootUrl": "https://localhost:44312"
      },
      "TravelPlanner_Swagger": {
        "ClientId": "TravelPlanner_Swagger",
        "RootUrl": "https://localhost:44312"
      }
    }
  }
}
