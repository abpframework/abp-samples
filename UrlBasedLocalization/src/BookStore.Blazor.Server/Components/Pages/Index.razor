@page "/"
@page "/{culture}"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using BookStore.Localization
@inject IStringLocalizer<BookStoreResource> L
@inject NavigationManager NavigationManager

@code {
    [Parameter]
    public string? Culture { get; set; }

    private void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url, forceLoad: true);
    }
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-10 offset-md-1">

            <div class="card shadow-sm mb-4">
                <div class="card-body p-5">
                    <h1 class="card-title mb-4">@L["Home:Title"]</h1>
                    <p class="lead text-muted">@L["Home:Description"]</p>

                    <hr />

                    <table class="table table-bordered">
                        <tr>
                            <th>@L["Home:CurrentCulture"]</th>
                            <td><span class="badge bg-primary fs-6">@CultureInfo.CurrentCulture.Name</span></td>
                        </tr>
                        <tr>
                            <th>Render type</th>
                            <td><code>Blazor Server (InteractiveServer)</code></td>
                        </tr>
                    </table>

                    <p class="text-muted small">@L["Home:TryIt"]</p>
                </div>
            </div>

            <div class="card border-success mb-4">
                <div class="card-header bg-success text-white">
                    @L["Home:TryLanguages"]
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-outline-success" @onclick='() => NavigateTo("/en")'>English — <code>/en</code></button>
                        <button class="btn btn-outline-success" @onclick='() => NavigateTo("/tr")'>Türkçe — <code>/tr</code></button>
                        <button class="btn btn-outline-success" @onclick='() => NavigateTo("/fr")'>Français — <code>/fr</code></button>
                        <button class="btn btn-outline-success" @onclick='() => NavigateTo("/zh-Hans")'>简体中文 — <code>/zh-Hans</code></button>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/en/About")'>English About</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/tr/About")'>Türkçe About</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/fr/About")'>Français About</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/zh-Hans/About")'>简体中文 About</button>
                    </div>
                </div>
            </div>

            <div class="card border-warning">
                <div class="card-header bg-warning">
                    @L["Home:UrlExample"]
                </div>
                <div class="card-body">
                    <p class="small text-muted">
                        Culture is detected from the URL path automatically.
                    </p>
                    <ul class="small">
                        <li><code>/en</code> → Index (English)</li>
                        <li><code>/tr</code> → Index (Türkçe)</li>
                        <li><code>/zh-Hans/About</code> → About (简体中文)</li>
                        <li><code>/fr/About</code> → About (Français)</li>
                    </ul>
                </div>
            </div>

            <div class="card border-secondary mt-4">
                <div class="card-header">
                    Module Page Routes (Dual <code>@@page</code> pattern)
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-3">
                        ABP built-in module pages (Identity, Settings, Tenant Management, etc.) ship with
                        both <code>/route</code> and <code>/{culture}/route</code> variants.
                        The page below demonstrates this same dual-route pattern.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/module-page")'>
                            /module-page
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/en/module-page")'>
                            /en/module-page
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/tr/module-page")'>
                            /tr/module-page
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/zh-Hans/module-page")'>
                            /zh-Hans/module-page
                        </button>
                    </div>
                </div>
            </div>

            <div class="card border-primary mt-4">
                <div class="card-header bg-primary text-white">
                    ABP Identity Module Pages (Real Module Test)
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-3">
                        These navigate to the real ABP Identity module pages.
                        Log in as <code>admin</code> / <code>1q2w3E*</code> first.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-outline-primary btn-sm" @onclick='() => NavigateTo("/identity/users")'>
                            /identity/users
                        </button>
                        <button class="btn btn-outline-primary btn-sm" @onclick='() => NavigateTo("/en/identity/users")'>
                            /en/identity/users
                        </button>
                        <button class="btn btn-outline-primary btn-sm" @onclick='() => NavigateTo("/tr/identity/users")'>
                            /tr/identity/users
                        </button>
                        <button class="btn btn-outline-primary btn-sm" @onclick='() => NavigateTo("/zh-Hans/identity/users")'>
                            /zh-Hans/identity/users
                        </button>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/identity/roles")'>
                            /identity/roles
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick='() => NavigateTo("/zh-Hans/identity/roles")'>
                            /zh-Hans/identity/roles
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
