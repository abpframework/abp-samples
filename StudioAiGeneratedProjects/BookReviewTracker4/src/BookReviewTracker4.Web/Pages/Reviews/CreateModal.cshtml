@page
@using Microsoft.Extensions.Localization
@using BookReviewTracker4.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@inject IStringLocalizer<BookReviewTracker4Resource> L
@model BookReviewTracker4.Web.Pages.Reviews.CreateModalModel
@{
    Layout = null;
}

<form asp-page="/Reviews/CreateModal" method="post">
    <abp-modal>
        <abp-modal-header title="@L["NewReview"].Value"></abp-modal-header>
        <abp-modal-body>
            <abp-select asp-for="Review.BookId" asp-items="@Model.Books" />
            <abp-select asp-for="Review.Rating" asp-items="@Model.Ratings" />
            <abp-input asp-for="Review.Comment" />
            <abp-input asp-for="Review.ReviewDate" />
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel | AbpModalButtons.Save)"></abp-modal-footer>
    </abp-modal>
</form>
