@page
@model BookStore.Mvc.Pages.IndexModel
@using System.Globalization
@using Microsoft.Extensions.Localization
@using BookStore.Localization
@inject IStringLocalizer<BookStoreResource> L

@{
    var currentCulture = CultureInfo.CurrentCulture.Name;
    var routeCulture = ViewContext.RouteData.Values["culture"]?.ToString() ?? "(none)";
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-10 offset-md-1">

            <div class="card shadow-sm mb-4">
                <div class="card-body p-5">
                    <h1 class="card-title mb-4">@L["Home:Title"]</h1>
                    <p class="lead text-muted">@L["Home:Description"]</p>

                    <hr />

                    <table class="table table-bordered">
                        <tr>
                            <th>@L["Home:CurrentCulture"]</th>
                            <td><span class="badge bg-primary fs-6">@currentCulture</span></td>
                        </tr>
                        <tr>
                            <th>Route {culture} value</th>
                            <td><code>@routeCulture</code></td>
                        </tr>
                    </table>

                    <p class="text-muted small">@L["Home:TryIt"]</p>
                </div>
            </div>

            <div class="card border-success mb-4">
                <div class="card-header bg-success text-white">
                    @L["Home:TryLanguages"]
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <a href="/en" class="btn btn-outline-success">English — <code>/en</code></a>
                        <a href="/tr" class="btn btn-outline-success">Türkçe — <code>/tr</code></a>
                        <a href="/fr" class="btn btn-outline-success">Français — <code>/fr</code></a>
                        <a href="/zh-Hans" class="btn btn-outline-success">简体中文 — <code>/zh-Hans</code></a>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <a href="/en/About" class="btn btn-outline-secondary btn-sm">English About</a>
                        <a href="/tr/About" class="btn btn-outline-secondary btn-sm">Türkçe About</a>
                        <a href="/fr/About" class="btn btn-outline-secondary btn-sm">Français About</a>
                        <a href="/zh-Hans/About" class="btn btn-outline-secondary btn-sm">简体中文 About</a>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- Razor Page navigation -->
                <div class="col-md-6">
                    <div class="card h-100 border-primary">
                        <div class="card-header bg-primary text-white">
                            Razor Page Links (Url.Page)
                        </div>
                        <div class="card-body">
                            <p class="small text-muted">
                                These links use plain <code>Url.Page()</code> — the culture route value
                                is automatically injected by the framework.
                            </p>
                            <div class="d-flex flex-column gap-2">
                                <a href="@Url.Page("/Index")" class="btn btn-outline-primary">
                                    Home — <code>@Url.Page("/Index")</code>
                                </a>
                                <a href="@Url.Page("/About")" class="btn btn-outline-primary">
                                    About — <code>@Url.Page("/About")</code>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MVC Controller navigation -->
                <div class="col-md-6">
                    <div class="card h-100 border-success">
                        <div class="card-header bg-success text-white">
                            MVC Controller Links (Url.Action)
                        </div>
                        <div class="card-body">
                            <p class="small text-muted">
                                MVC Controller demo — culture is also automatically injected.
                            </p>
                            <div class="d-flex flex-column gap-2">
                                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-success">
                                    MVC Home — <code>@Url.Action("Index", "Home")</code>
                                </a>
                                <a href="@Url.Action("About", "Home")" class="btn btn-outline-success">
                                    MVC About — <code>@Url.Action("About", "Home")</code>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- URL examples -->
                <div class="col-12">
                    <div class="card border-warning">
                        <div class="card-header bg-warning">
                            @L["Home:UrlExample"]
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>Razor Page routes:</strong>
                                    <ul class="mt-2 small">
                                        <li><code>/en</code> → Index (English)</li>
                                        <li><code>/tr</code> → Index (Türkçe)</li>
                                        <li><code>/zh-Hans/About</code> → About (中文)</li>
                                    </ul>
                                </div>
                                <div class="col-md-6">
                                    <strong>MVC Controller routes:</strong>
                                    <ul class="mt-2 small">
                                        <li><code>/en/Home/Index</code> → HomeController.Index (English)</li>
                                        <li><code>/tr/Home/About</code> → HomeController.About (Türkçe)</li>
                                        <li><code>/Home/About</code> → HomeController.About (no culture prefix)</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
